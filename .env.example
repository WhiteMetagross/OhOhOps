# Local mode starts without paid services when mock mode is enabled.
DEPLOYMENT_MODE=local
CHROMA_HOST=chromadb
CHROMA_PORT=8000
SANDBOX_MODE=docker
SANDBOX_MEM_LIMIT=256m
SANDBOX_TIMEOUT_SECONDS=60
USE_MOCK_LLM=true
USE_LOCAL_EMBEDDINGS=false
ENABLE_TELEMETRY_LOOP=false
ENABLE_POST_HEAL_RESTART=false

# Replace these before exposing a deployment.
OHOHOPS_API_KEY=replace-with-a-long-random-value
OHOHOPS_WEBHOOK_SECRET=replace-with-a-long-random-value

# Real model providers. Configure at least two distinct security model IDs.
GEMINI_API_KEY=
GEMINI_API_KEY_CHAT=
GEMINI_API_KEY_SECURITY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Embeddings. OpenAI text-embedding-3-large is native 3072 dimensions.
OPENAI_API_KEY=

# Cloud services.
PINECONE_API_KEY=
SUPABASE_DB_URL=

# Optional private GitHub repository ingestion.
GITHUB_TOKEN=
